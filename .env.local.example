# ============================================================
# harga.com — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

# Public URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key (safe to expose — protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (SECRET — server-side only, bypasses RLS)
# Used in API routes and seed scripts. NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct DB connection (for migrations / seeding only)
# Found in: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres

# ── App config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=harga.com

# ── Affiliate networks (Phase 3) ─────────────────────────────
# Shopee Affiliate
SHOPEE_AFFILIATE_ID=your_shopee_affiliate_id

# Involve Asia
INVOLVE_ASIA_API_KEY=your_involve_asia_key
INVOLVE_ASIA_PUBLISHER_ID=your_publisher_id

# Accesstrade
ACCESSTRADE_API_KEY=your_accesstrade_key

# ── Redis / Bull queue (Phase 3 — scraper) ───────────────────
REDIS_URL=redis://localhost:6379

# ── Optional: analytics ──────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_GA_ID=
